{
  "openapi": "3.1.0",
  "info": { "title": "t", "version": "0.9.0" },
  "paths": {
    "/file/{file_id}/status": {
      "get": {
        "summary": "查状态",
        "parameters": [
          { "name": "file_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "文件ID" }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/FileStatus" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/file/parse": {
      "post": {
        "summary": "解析",
        "parameters": [
          { "name": "mode", "in": "query", "required": false, "schema": { "type": "string", "enum": ["async", "sync"], "default": "async" }, "description": "模式" }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParseReq" } } }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "data": { "type": "object", "properties": { "file_id": { "type": "string", "description": "文件ID" } } } }
                }
              }
            }
          }
        }
      }
    },
    "/file/{file_id}/tables": {
      "get": {
        "summary": "表格",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/TableItem" } } }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FileStatus": {
        "type": "object",
        "required": ["file_id"],
        "properties": {
          "file_id": { "type": "string", "description": "文件ID" },
          "error": { "anyOf": [{ "type": "string" }, { "type": "null" }], "description": "错误信息" },
          "source_refs": { "anyOf": [{ "type": "object" }, { "type": "null" }], "description": "溯源" }
        }
      },
      "ParseReq": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": { "type": "string", "description": "PDF 文件" },
          "type_id": { "type": "string", "default": "default", "description": "文档类型" }
        }
      },
      "TableItem": {
        "type": "object",
        "properties": {
          "table_name": { "type": "string", "description": "表名" },
          "page_num": { "anyOf": [{ "type": "string" }, { "type": "null" }], "description": "页码" }
        }
      }
    }
  }
}
