# ============================================================
# 析卷 AI 配置文件示例
# 复制为 config.yaml 后修改为实际值
# 字段名与 utils/config.py 中的 Pydantic 模型一一对应
# ============================================================

# 服务器配置
server:
  host: "0.0.0.0"
  port: 5019

# MinerU PDF 解析服务配置
mineru:
  base_url: "http://your-mineru-server:7078"
  backend: "vllm-async-engine"
  queue_width: 1
  parse_timeout: 1200        # 解析超时（秒）
  max_file_size: 104857600   # 最大文件大小（字节），默认 100MB

# 文本分块配置
chunking:
  chunk_size: 512            # 目标块大小（字符数）
  chunk_overlap: 50          # 块间重叠字符数
  max_chunk_size: 2048       # 最大块大小
  separators: ["\n\n", "\n", "。", " "]  # 分割符优先级

# 向量化（Embedding）配置
embedding:
  base_url: "http://your-embedding-server:8119/v1"
  model_name: "your-embedding-model"
  api_key: "your-api-key"
  embedding_dim: 4096        # 向量维度
  batch_size: 10             # 批量请求数
  timeout: 60                # 请求超时（秒）
  retry_count: 3             # 重试次数

# Milvus 向量数据库配置
milvus:
  host: "your-milvus-host"
  port: 19530
  user: ""
  password: ""
  collection_name: "your_collection_name"
  index_type: "IVF_FLAT"
  metric_type: "L2"
  nlist: 4096
  search_topk: 10

# MySQL 数据库配置
mysql:
  host: "127.0.0.1"
  port: 3306
  database: "your_database"
  username: "your_username"
  password: "your_password"
  pool_size: 50          # 常驻连接数(每个进程一份)
  max_overflow: 10       # 突发可临时额外创建的连接数,峰值 = pool_size + max_overflow
  pool_timeout: 10       # 连接池满时等待连接的秒数,超时抛 TimeoutError

# 字段提取配置（LLM 相关）
extraction:
  llm_base_url: "http://your-llm-server:8119/v1"
  llm_model: "your-llm-model"
  llm_api_key: "your-api-key"
  llm_timeout: 60            # LLM 请求超时（秒）
  llm_retry_count: 3         # LLM 重试次数
  max_context_length: 4096   # 最大上下文长度
  # LLM 额外请求参数，直接写入请求体的 extra_body 字段
  # 自部署模型（vLLM / Ollama 等）关闭思考链示例：
  #   llm_extra_body: {chat_template_kwargs: {enable_thinking: false}}
  # 阿里 DashScope 等托管模型关闭思考链示例：
  #   llm_extra_body: {enable_thinking: false}
  # 不需要额外参数时留空：
  llm_extra_body: {}

# 表格名校验配置（独立于 extraction，字段含义相同）
# 未配置的字段会回退到 extraction 的对应值
table_name_validation:
  llm_base_url: null
  llm_model: null
  llm_api_key: null
  llm_timeout: null
  llm_retry_count: null
  max_context_length: null
  max_context_lines: 3       # 表格名提取时参考的最大行数
  max_concurrency: 20        # 并发 LLM 请求数
  llm_extra_body: null

# 逻辑分析配置
analysis:
  calc_precision: 2          # 计算结果小数精度
  judge_timeout: 30          # 判定超时（秒）

# VL（视觉模型）抽取配置
vl_model:
  base_url: "http://your-vl-server:8119/v1"
  api_key: "your-api-key"
  model: "your-vl-model"
  temperature: 0.1
  max_tokens: 4096
  timeout: 180               # VL 请求超时（秒）
  extra_body: {}
  global_max_concurrency: 8  # 全局最大并发数
  default_max_pixels: 4000000 # 默认最大像素数（4MP）
  pdf_storage_dir: "uploads" # PDF 文件存储目录

# 网络搜索配置（博查 Bocha AI，逻辑分析 judge 规则使用）
web_search:
  base_url: "https://api.bochaai.com/v1/web-search"
  api_key: "your-api-key"
  count: 5              # 默认返回条数
  summary: true         # 返回长摘要
  freshness: "noLimit"  # 默认时间范围 noLimit/oneDay/oneWeek/oneMonth/oneYear
  timeout: 10
  retry_count: 2
  max_result_length: 4000  # 注入 prompt 的搜索文本最大字符数（末尾截断）

# PDF 存储治理配置
# uploads 下原始 PDF 的清理策略；只删物理 PDF 文件，不动数据库
# 被清文件的解析/抽取结果仍可查，仅 PDF 预览（GET /file/{id}/pdf）与 VL 抽取会 404
storage:
  max_total_bytes: 0            # PDF 总大小上限(字节)，0=不限。超限时按 create_time 最旧优先淘汰。例:10737418240=10GB
  max_retention_minutes: 0      # PDF 最久保存时间(分钟)，0=不限。超过则删除物理 PDF。例:4320=3天
  cleanup_interval_minutes: 10  # 后台清理扫描周期(分钟)
